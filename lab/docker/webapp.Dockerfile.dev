# Dev-mode image only -- runs `next dev`, not a production build.
# Build context is the repo root (.. from lab/). The bind mount in
# docker-compose.yml overlays /app so edits on the host hot-reload here.
FROM node:20-alpine
WORKDIR /app

COPY apps/web/idam2-demo-finance/package.json \
     apps/web/idam2-demo-finance/package-lock.json \
     apps/web/idam2-demo-finance/

RUN npm ci --prefix apps/web/idam2-demo-finance

COPY apps/web/idam2-demo-finance apps/web/idam2-demo-finance

WORKDIR /app/apps/web/idam2-demo-finance
EXPOSE 3000
CMD ["npm", "run", "dev", "--", "--webpack", "-p", "3000", "-H", "0.0.0.0"]
