# Stub dev image until services/mcp-server is implemented.
# Enable with: docker compose --profile mcp up --build
FROM node:20-alpine
WORKDIR /app

COPY services/mcp-server/package.json services/mcp-server/package-lock.json* ./

RUN npm install

COPY services/mcp-server ./

EXPOSE 8000
CMD ["npm", "run", "dev"]
